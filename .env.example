# Copy to .env and adjust as needed.
PGUSER=srp
PGPASSWORD=srp
PGDATABASE=srp

# Simulator behaviour
BACKFILL_HOURS=72      # hours of history generated on first start
LIVE_INTERVAL=15       # seconds between live card rounds (accelerated demo)
DO_BACKFILL=true
DO_LIVE=true

# Grafana admin password
GRAFANA_PASSWORD=admin
